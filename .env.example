# Din Collection ERP - Environment Variables
# Copy this file to .env and fill in your values

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Database (for migrations / test scripts; use .env.local)
# Direct: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# If you get ENOTFOUND, use Connection pooler URI from Supabase Dashboard → Database → Connection pooling
# DATABASE_POOLER_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# DATABASE_URL=
# DATABASE_POOLER_URL=

# Optional: Next.js format (if migrating)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
