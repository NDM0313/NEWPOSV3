VITE_SUPABASE_URL=https://supabase.dincouture.pk

# Accounting canonical guards (accountingCanonicalGuard.ts)
# In dev/staging: legacy reads throw by default (Phase 3, 2026-04-12).
# To opt out of hard fail in dev: set to false
# VITE_ACCOUNTING_LEGACY_HARD_FAIL=false
# To enable additional debug logging of source assertions:
# VITE_ACCOUNTING_DEBUG_SOURCES=true
VITE_SUPABASE_ANON_KEY=PASTE_ANON_KEY_HERE

SUPABASE_URL=https://supabase.dincouture.pk
SUPABASE_ANON_KEY=PASTE_ANON_KEY_HERE
# Must be the long JWT from Dashboard → API → service_role (starts with eyJ…), not sb_secret_… or the anon key
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVICE_ROLE_KEY_HERE

APP_URL=http://localhost:5173
ERP_APP_URL=https://erp.dincouture.pk
SUPABASE_STUDIO_URL=https://studio.dincouture.pk