   if (legacyRows.length === 0) {\n      await markLegacyMigrationDone(0);\n      return 0;\n    }\n    const existing = await readAllWorkers();\n    const existingHashes = new Set(existing.map((r) => r.pinHash));\n    let migrated = 0;\n    const database = await openRegistryDb();\n    await new Promise<void>((resolve, reject) => {\n      const tx = database.transaction(STORE, 'readwrite');\n      const store = tx.objectStore(STORE);\n      for (const legacy of legacyRows) {\n        if (!legacy.pinHash || !legacy.userId) continue;\n        if (existingHashes.has(legacy.pinHash)) continue;\n        const row: StoredWorkerRow = {\n          pinHash: legacy.pinHash,\n          userId: legacy.userId,\n          displayName: legacy.displayName?.trim() || legacy.email?.trim() || 'User',\n          email: legacy.email?.trim() || '',\n          role: legacy.role?.trim() || '',\n          companyId: legacy.companyId?.trim() || '',\n          branchId: null,\n          enrolledAt: Date.now(),\n        };\n        store.put(row);\n        existingHashes.add(legacy.pinHash);\n        migrated += 1;\n      }\n      tx.oncomplete = () => resolve();\n      tx.onerror = () => reject(tx.error);\n    });\n    await markLegacyMigrationDone(migrated);\n    if (migrated > 0) {\n      console.info(`[ERP Mobile] Migrated ${migrated} counter worker(s) from legacy vault.`);\n    }\n    return migrated;\n  })", "is_member_call": false, "source_file": "/Users/ndm/Documents/Development/CursorDev/NEWPOSV3/erp-mobile-app/src/lib/counterWorkerRegistry.ts", "source_location": "L195"}, {"caller_nid": "lib_counterworkerregistry_listenrolledworkers", "callee": "map", "is_member_call": true, "source_file": "/Users/ndm/Documents/Development/CursorDev/NEWPOSV3/erp-mobile-app/src/lib/counterWorkerRegistry.ts", "source_location": "L247"}, {"caller_nid": "lib_counterworkerregistry_listenrolledworkers", "callee": "filter", "is_member_call": true, "source_file": "/Users/ndm/Documents/Development/CursorDev/NEWPOSV3/erp-mobile-app/src/lib/counterWorkerRegistry.ts", "source_location": "L247"}, {"caller_nid": "lib_counterworkerregistry_countworkers", "callee": "filter", "is_member_call": true, "source_file": "/Users/ndm/Documents/Development/CursorDev/NEWPOSV3/erp-mobile-app/src/lib/counterWorkerRegistry.ts", "source_location": "L256"}, {"caller_nid": "lib_counterworkerregistry_removeduplicateuserentries", "callee": "filter", "is_member_call": true, "source_file": "/Users/ndm/Documents/Development/CursorDev/NEWPOSV3/erp-mobile-app/src/lib/counterWorkerRegistry.ts", "source_location": "L282"}, {"caller_nid": "lib_counterworkerregistry_findenrolledworkerbyidentity", "callee": "find", "is_member_call": true, "source_file": "/Users/ndm/Documents/Development/CursorDev/NEWPOSV3/erp-mobile-app/src/lib/counterWorkerRegistry.ts", "source_location": "L311"}, {"caller_nid": "lib_counterworkerregistry_savecounterworkerwithpinhash", "callee": "trim", "is_member_call": true, "source_file": "/Users/ndm/Documents/Development/CursorDev/NEWPOSV3/erp-mobile-app/src/lib/counterWorkerRegistry.ts", "source_location": "L319"}, {"caller_nid": "lib_counterworkerregistry_savecounterworkerwithpinhash", "callee": "trim", "is_member_call": true, "source_file": "/Users/ndm/Documents/Development/CursorDev/NEWPOSV3/erp-mobile-app/src/lib/counterWorkerRegistry.ts", "source_location": "L320"}, {"caller_nid": "lib_counterworkerregistry_savecounterworkerwithpinhash", "callee": "trim", "is_member_call": true, "source_file": "/Users/ndm/Documents/Development/CursorDev/NEWPOSV3/erp-mobile-app/src/lib/counterWorkerRegistry.ts", "source_location": "L321"}, {"caller_nid": "lib_counterworkerregistry_savecounterworkerwithpinhash", "callee": "trim", "is_member_call": true, "source_file": "/Users/ndm/Documents/Development/CursorDev/NEWPOSV3/erp-mobile-app/src/lib/counterWorkerRegistry.ts", "source_location": "L323"}, {"caller_nid": "lib_counterworkerregistry_savecounterworkerwithpinhash", "callee": "trim", "is_membe