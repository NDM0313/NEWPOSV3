# Copy to keystore.properties in this folder (gitignored).
# Paths are relative to the android/ project root.
#
# Create an upload keystore once, e.g.:
# keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload

storePassword=iPhone@14max
keyPassword=iPhone@14max
keyAlias=my-key-alias
storeFile=app/release-key.jks
