{
  "name": "erp-mobile-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "typecheck": "tsc -b",
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "build:mobile": "vite build",
    "build:mobile:prod": "vite build --mode production",
    "build:mobile:pwa": "VITE_BASE=/m/ vite build && node scripts/rewrite-pwa-base.js",
    "cap:sync": "npm run build:mobile && npx cap sync",
    "cap:sync:android": "npm run build:mobile && npx cap sync android",
    "cap:sync:android:prod": "npm run build:mobile:prod && npx cap sync android",
    "cap:sync:ios": "npm run build:mobile && npx cap sync ios",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "android:debug": "npm run cap:sync:android && cd android && ./gradlew assembleDebug",
    "android:debug:win": "npm run cap:sync:android && cd android && gradlew.bat assembleDebug",
    "android:bundle": "cd android && ./gradlew bundleRelease",
    "android:bundle:win": "cd android && gradlew.bat bundleRelease",
    "android:apk:release": "cd android && ./gradlew assembleRelease",
    "android:apk:release:win": "npm run cap:sync:android:prod && cd android && gradlew.bat assembleRelease",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.0",
    "@capacitor-mlkit/barcode-scanning": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.0",
    "@supabase/realtime-js": "^2.95.3",
    "@supabase/supabase-js": "^2.95.3",
    "crypto-js": "^4.2.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.487.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@types/crypto-js": "^4.2.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "patch-package": "^8.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.2.0"
  }
}
