# Single Core Ledger — VPS isolated clone validation (example)
# Copy to .env.local for local runs against SSH tunnel, OR set on VPS only.
# NEVER commit .env.local

UNIFIED_LEDGER_STAGING=1
UNIFIED_LEDGER_VPS_CLONE=1
UNIFIED_LEDGER_PG_ONLY=1
UNIFIED_LEDGER_TIEOUT_STAGING=1

# Isolated clone — NOT the live `postgres` database
CLONE_DB=ledger_stage_20260623
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/ledger_stage_20260623

# Do NOT set VITE_SUPABASE_URL to production when using VPS clone pg-only mode.
